# ================================
# AffairGo .env.local Vorlage
# Diese Datei als .env.local kopieren
# cp .env.local.example .env.local
#
# Nur Werte eintragen, die lokal oder im Web-Hosting benoetigt werden.
# AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY und PROFILE_IMAGE_VERIFICATION_SIGNING_KEY
# gehoeren NICHT hier hinein. Diese liegen in Firebase Functions Secrets.
# ================================

# -------------------------------
# Firebase Web App Config
# Quelle: Firebase Console -> Projekteinstellungen -> Allgemein -> Deine Apps -> Web-App
# Diese Werte braucht der Expo-/Web-Client direkt.
# -------------------------------
EXPO_PUBLIC_FIREBASE_API_KEY=PASTE_FIREBASE_WEB_API_KEY_HERE
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.region.firebasedatabase.app
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
EXPO_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:yourappid
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# -------------------------------
# Stadia Maps
# Eintragen: dein oeffentlicher Stadia Maps Tile API Key
# Quelle: Stadia Maps Dashboard
# -------------------------------
EXPO_PUBLIC_STADIA_API_KEY=PASTE_STADIA_MAPS_PUBLIC_TILE_API_KEY_HERE

# -------------------------------
# Selfie- und KI-Fakecheck Backend
# Eintragen: Base URL deines Selfie-/Deepfake-/Liveness-Backends
# Optional: oeffentlicher Client-Token fuer dieses Backend
# Wenn du die eingebauten /api-Routen lokal nutzt, koennen die Default-Pfade so bleiben.
# -------------------------------
EXPO_PUBLIC_SELFIE_VERIFICATION_PROVIDER=custom
EXPO_PUBLIC_SELFIE_VERIFICATION_BASE_URL=/api/selfie-ai
EXPO_PUBLIC_SELFIE_VERIFICATION_PUBLIC_TOKEN=PASTE_SELFIE_BACKEND_PUBLIC_API_TOKEN_HERE

# -------------------------------
# Moderation / Abuse / Fraud Backend
# Eintragen: Base URL deines Moderations-Backends
# Optional: oeffentlicher Client-Token fuer dieses Backend
# -------------------------------
EXPO_PUBLIC_MODERATION_PROVIDER=custom
EXPO_PUBLIC_MODERATION_BASE_URL=/api/moderation
EXPO_PUBLIC_MODERATION_PUBLIC_TOKEN=PASTE_MODERATION_BACKEND_PUBLIC_API_TOKEN_HERE

# -------------------------------
# Payments / Store / Billing
# Nur noetig, wenn du die Bezahlfunktion spaeter wieder aktivierst.
# Eintragen: Base URL deines Billing-Backends und optional oeffentlicher Token.
# -------------------------------
EXPO_PUBLIC_PAYMENT_PROVIDER=custom
EXPO_PUBLIC_PAYMENT_BASE_URL=/api/billing
EXPO_PUBLIC_PAYMENT_PUBLIC_TOKEN=PASTE_PAYMENT_BACKEND_PUBLIC_API_TOKEN_HERE
EXPO_PUBLIC_STRIPE_CHECKOUT_URL=https://checkout.stripe.com/pay/your-session
EXPO_PUBLIC_APPLE_STORE_URL=https://apps.apple.com/
EXPO_PUBLIC_GOOGLE_PLAY_URL=https://play.google.com/store

# -------------------------------
# Passwort-Reset
# EXPO_PUBLIC_PASSWORD_RESET_BASE_URL: Base URL fuer den Passwort-Reset-Endpunkt
# AFFAIRGO_PASSWORD_RESET_WEBHOOK_URL: serverseitiger Mail-/Webhook-Endpunkt fuer temporaere Passwoerter oder eigene Reset-Mails
# Wenn kein Webhook gesetzt ist, faellt die App auf Firebase Password Reset zurueck.
# -------------------------------
EXPO_PUBLIC_PASSWORD_RESET_BASE_URL=/api/auth
AFFAIRGO_PASSWORD_RESET_WEBHOOK_URL=

# -------------------------------
# AWS Face Liveness Webflow
# AWS_COGNITO_IDENTITY_POOL_ID: Cognito Identity Pool ID fuer kurzlebige Browser-Credentials
# AWS_COGNITO_REGION: AWS Region des Identity Pools und von Rekognition
# EXPO_PUBLIC_PROFILE_PHOTO_LIVENESS_WEB_URL: optionale Override-URL fuer die Liveness-Webseite
# -------------------------------
AWS_COGNITO_IDENTITY_POOL_ID=eu-central-1:paste-your-cognito-identity-pool-id-here
AWS_COGNITO_REGION=eu-central-1
EXPO_PUBLIC_PROFILE_PHOTO_LIVENESS_WEB_URL=/api/profile-photo-liveness